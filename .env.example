# 复制为 .env.local 后填入真实值，再运行 npx vercel dev

# 必填：AI 点评 / 项目教练 / 训练智能体
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# 可选：Claude 二选一
# ANTHROPIC_API_KEY=
# AI_PROVIDER=anthropic

# 可选：语音转写
# OPENAI_API_KEY=

# 本地免登录单人版；Vercel 生产环境建议 AUTH_DISABLED=1
AUTH_DISABLED=1

# 单人本地使用：不配 ACCESS_CODE / ACCESS_USERS 即自动访客模式，无需注册登录
# 若需密码保护，可设置 ACCESS_CODE 并将 AUTH_DISABLED=0

# Vercel 部署：DEEPSEEK_API_KEY（必填）+ AUTH_DISABLED=1（推荐）

# 可选：答题历史 / 成长曲线（不配也能练题）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
