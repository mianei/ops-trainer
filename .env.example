# 复制为 .env.local 后填入真实值，再运行 npx vercel dev

# 必填：AI 点评 / 项目教练 / 训练智能体
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# 可选：Claude 二选一
# ANTHROPIC_API_KEY=
# AI_PROVIDER=anthropic

# 可选：语音转写
# OPENAI_API_KEY=

# 生产推荐：开启登录注册（需 Upstash + 邀请码）
AUTH_DISABLED=0

# 注册邀请码（与 ACCESS_CODE 二选一即可作为邀请码来源）
REGISTER_INVITE_CODE=654123

# 答题历史 / 成长曲线 / 用户账号（生产必填）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 管理员后台密钥（仅 /admin 使用，勿泄露）
ADMIN_SECRET=your-admin-secret

# 本地单人免登录调试时可设 AUTH_DISABLED=1（访客模式）
# 可选：环境变量账号（逗号分隔 user:pass），与 Upstash 注册账号并存
# ACCESS_USERS=alice:secret123,bob:pass456
# ACCESS_CODE=legacy-single-password
