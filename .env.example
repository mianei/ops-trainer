# 复制为 .env.local 后填入真实值，再运行 npx vercel dev

# 必填：AI 点评 / 项目教练 / 训练智能体
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# 可选：Claude 二选一
# ANTHROPIC_API_KEY=
# AI_PROVIDER=anthropic

# 可选：语音转写
# OPENAI_API_KEY=

# 本地免登录；Vercel 生产环境建议 AUTH_DISABLED=1（未配 ACCESS_CODE 时也可访客使用）
AUTH_DISABLED=1

# Vercel 部署：在 Project → Settings → Environment Variables 配置
# - DEEPSEEK_API_KEY（必填，否则简历评分/教练接口返回 503）
# - AUTH_DISABLED=1（推荐；若 AUTH_DISABLED=0 且未配 ACCESS_CODE，将自动以访客放行）

# 可选：答题历史 / 成长曲线（不配也能练题）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
